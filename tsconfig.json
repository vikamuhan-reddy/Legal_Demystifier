{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "es2020"],
    "module": "commonjs",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "noImplicitAny": false
  },
  "include": ["api/**/*.ts", "frontend/**/*.ts", "frontend/**/*.tsx", "types.ts"],
  "exclude": ["node_modules"]
}
